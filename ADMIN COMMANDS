	task.wait(d)
	i:Destroy()
end

local function gpfs(a,p)
	if not a then return {} end
	local n = a[2] and a[2]:lower()
	local x = Players:GetPlayers()

	if n == "me" then
		return {p}
	elseif n == "all" then
		return x
	else
		for _,v in ipairs(x) do
			if v.Name:lower():sub(1,#n) == n then
				return {v}
			end
		end
	end

	return {}
end


